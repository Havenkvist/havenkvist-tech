# Resend API key used by src/app/api/contact/route.ts to send contact form emails.
# Get one at https://resend.com after creating a free account.
RESEND_API_KEY=

# Address the contact form delivers messages to. Defaults to hey@havenkvist.tech.
CONTACT_TO_EMAIL=hey@havenkvist.tech

# Verified "from" address for outgoing mail. Until you verify your own domain
# in Resend, you must use their shared onboarding@resend.dev sender.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Optional: verification token from Google Search Console (Settings > Ownership
# verification > HTML tag > copy just the content="..." value). Adds the
# google-site-verification meta tag so you can verify both domains.
GOOGLE_SITE_VERIFICATION=
